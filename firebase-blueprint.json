{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and subscription status",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string", "description": "User's full name" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "country": { "type": "string", "description": "User's country" },
        "currency": { "type": "string", "description": "User's preferred currency (₹ or $)" },
        "isPro": { "type": "boolean", "description": "Whether the user has a pro subscription" },
        "isAdmin": { "type": "boolean", "description": "Whether the user is an administrator" },
        "trialStartDate": { "type": "string", "format": "date-time", "description": "When the user started their free trial" },
        "proExpiryDate": { "type": "string", "format": "date-time", "description": "When the pro subscription expires" }
      },
      "required": ["uid", "email", "trialStartDate"]
    },
    "Config": {
      "title": "Config",
      "description": "Global application configuration",
      "type": "object",
      "properties": {
        "proPriceMonthly": { "type": "number", "description": "Monthly Pro price" },
        "proPriceYearly": { "type": "number", "description": "Yearly Pro price" },
        "proPriceMonthlyOld": { "type": "number", "description": "Old monthly Pro price" },
        "proPriceYearlyOld": { "type": "number", "description": "Old yearly Pro price" }
      },
      "required": ["proPriceMonthly", "proPriceYearly"]
    },
    "Subscription": {
      "title": "Subscription",
      "description": "A user's subscription record",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner's UID" },
        "name": { "type": "string", "description": "Subscription name" },
        "price": { "type": "number", "description": "Price of the subscription" },
        "billingCycle": { "type": "string", "enum": ["monthly", "yearly"], "description": "Billing frequency" },
        "nextRenewal": { "type": "string", "format": "date-time", "description": "Next renewal date" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the subscription was added" },
        "category": { "type": "string", "enum": ["Entertainment", "Productivity", "Utilities", "Food", "Health", "Other"], "description": "Subscription category" },
        "status": { "type": "string", "enum": ["active", "paused"], "description": "Subscription status" },
        "icon": { "type": "string", "description": "Icon name or identifier" }
      },
      "required": ["uid", "name", "price", "billingCycle", "nextRenewal", "createdAt", "category", "status"]
    },
    "Message": {
      "title": "Message",
      "description": "A message from a user to the admin",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Sender's UID" },
        "email": { "type": "string", "format": "email", "description": "Sender's email" },
        "content": { "type": "string", "description": "Message content" },
        "sentAt": { "type": "string", "format": "date-time", "description": "When the message was sent" },
        "status": { "type": "string", "enum": ["unread", "read", "replied"], "description": "Message status" },
        "reply": { "type": "string", "description": "Admin's reply" },
        "repliedAt": { "type": "string", "format": "date-time", "description": "When the admin replied" }
      },
      "required": ["uid", "email", "content", "sentAt", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/subscriptions/{subId}": {
      "schema": "Subscription",
      "description": "Subscription records"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "User messages to admin"
    },
    "/config/{configId}": {
      "schema": "Config",
      "description": "Global application configuration"
    }
  }
}
